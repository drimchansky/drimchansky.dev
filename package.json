{
  "name": "drimchansky.dev",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "env": "cat .env.example > .env",
    "test:e2e": "sh scripts/test.sh tests/e2e",
    "test:visual": "sh scripts/test.sh tests/visual",
    "test:visual:update": "sh scripts/test.sh tests/visual --update-snapshots",
    "test:unit": "vitest run",
    "lint": "astro check && eslint .",
    "format": "prettier --write . && eslint --fix .",
    "test": "pnpm lint && pnpm test:unit && sh scripts/test.sh"
  },
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/markdown-remark": "7.1.0",
    "@astrojs/mdx": "5.0.3",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@tailwindcss/vite": "4.2.2",
    "astro": "6.1.5",
    "astro-icon": "1.1.5",
    "date-fns": "4.1.0",
    "dotenv": "17.4.1",
    "focus-trap": "8.0.1",
    "markdown-it": "14.1.1",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "rehype-slug": "6.0.0",
    "sanitize-html": "2.17.2",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.59.1",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.6.0",
    "@types/sanitize-html": "2.16.1",
    "@typescript-eslint/parser": "8.58.1",
    "astro-eslint-parser": "1.4.0",
    "eslint": "10.2.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-perfectionist": "5.8.0",
    "eslint-plugin-promise": "7.2.1",
    "postcss-html": "1.8.1",
    "prettier": "3.8.2",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "stylelint": "17.6.0",
    "stylelint-config-html": "1.1.0",
    "stylelint-config-idiomatic-order": "10.0.0",
    "stylelint-config-recommended": "18.0.0",
    "stylelint-order": "8.1.1",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  },
  "pnpm": {
    "overrides": {
      "sharp": "0.34.5",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "tar@<=7.5.10": ">=7.5.11",
      "devalue@<5.6.4": ">=5.6.4",
      "devalue@<=5.6.3": ">=5.6.4",
      "flatted@<3.4.0": ">=3.4.0",
      "yauzl@<3.2.1": ">=3.2.1",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0"
    },
    "peerDependencyRules": {
      "allowAny": [
        "eslint"
      ]
    },
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
