{
  "name": "drimchansky.dev",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "env": "cat .env.example > .env",
    "test:e2e": "sh scripts/test.sh tests/e2e",
    "test:visual": "sh scripts/test.sh tests/visual",
    "test:visual:update": "sh scripts/test.sh tests/visual --update-snapshots",
    "lint": "astro check && eslint .",
    "format": "prettier --write . && eslint --fix .",
    "test": "pnpm lint && sh scripts/test.sh"
  },
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "dependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/markdown-remark": "^7.0.0",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.3",
    "astro-icon": "^1.1.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "focus-trap": "^8.0.0",
    "markdown-it": "^14.1.1",
    "postcss-html": "^1.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.58.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.3.5",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/parser": "^8.56.1",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^10.0.3",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-promise": "^7.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.4.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-order": "^7.0.1",
    "typescript-eslint": "^8.56.1"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.34.3"
    },
    "peerDependencyRules": {
      "allowAny": [
        "eslint"
      ]
    },
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
