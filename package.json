{
  "name": "drimchansky.dev",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "env": "[ -f .env ] || cp .env.example .env",
    "lfs": "git-lfs pull",
    "test:e2e": "sh scripts/test.sh tests/e2e",
    "test:visual": "sh scripts/test.sh tests/visual",
    "test:visual:update": "sh scripts/test.sh tests/visual --update-snapshots",
    "test:unit": "vitest run",
    "lint": "astro check && eslint .",
    "format": "prettier --write . && eslint --fix .",
    "test": "pnpm lint && pnpm test:unit && sh scripts/test.sh"
  },
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "7.2.0",
    "@astrojs/mdx": "6.0.3",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@tailwindcss/vite": "4.3.1",
    "astro": "6.4.6",
    "astro-icon": "1.1.5",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "focus-trap": "8.2.1",
    "markdown-it": "14.2.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "rehype-slug": "6.0.0",
    "sanitize-html": "2.17.5",
    "sharp": "0.35.1",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.60.0",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.9.3",
    "@types/sanitize-html": "2.16.1",
    "@typescript-eslint/parser": "8.61.0",
    "astro-eslint-parser": "1.4.0",
    "eslint": "10.5.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-promise": "7.3.0",
    "postcss-html": "1.8.1",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "stylelint": "17.13.0",
    "stylelint-config-html": "1.1.0",
    "stylelint-config-idiomatic-order": "10.0.0",
    "stylelint-config-recommended": "18.0.0",
    "stylelint-order": "8.1.1",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  }
}
