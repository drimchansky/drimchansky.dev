---
import type { GetStaticPaths } from 'astro'

import { supportedLocales, t } from '@/app/i18n'
import BaseLayout from '@/app/layouts/base-layout.astro'
import { Header } from '@/components/header'
import { siteInfo } from '@/shared/site-info'
import Avatar from '@/shared/ui/avatar.astro'
import Container from '@/shared/ui/container.astro'
import TypographyH1 from '@/shared/ui/typography/typography-h1.astro'
import TypographyP from '@/shared/ui/typography/typography-p.astro'
import TypographySpan from '@/shared/ui/typography/typography-span.astro'

export const getStaticPaths = (async () =>
  supportedLocales.map(lang => ({ params: { lang } }))) satisfies GetStaticPaths
---

<BaseLayout title={t(Astro.currentLocale, 'fullName')}>
  <Header slot="header" />

  <Container content class="flex min-h-[calc(100dvh-var(--header-height))] flex-col justify-center">
    <div class="flex flex-col gap-2 portrait:mt-0 [@media(orientation:landscape)_and_(max-height:500px)]:flex-row">
      <Avatar />
      <TypographyH1 class="[&>span]:text-[4rem] [&>span]:leading-none">
        <span itemprop="givenName">{t(Astro.currentLocale, 'givenName')}</span>
        <span itemprop="familyName">{t(Astro.currentLocale, 'familyName')}</span>
      </TypographyH1>

      <TypographyP class="max-w-150 text-lg font-normal text-balance">
        {t(Astro.currentLocale, 'intro')}
      </TypographyP>

      <div class="flex flex-wrap gap-1" data-nosnippet>
        {
          siteInfo.socialLinks.map(
            ({ name, showOnHomePage, url }) =>
              showOnHomePage && (
                <a
                  class="text-fg-muted link-underline focus-ring hoverable:text-fg p-1 opacity-80 transition-colors duration-(--link-hover-duration) [&_span]:text-lg"
                  href={url}
                  itemprop="sameAs"
                  rel="me"
                  target="_blank"
                >
                  <TypographySpan>{name}</TypographySpan>
                </a>
              )
          )
        }
      </div>
    </div>
  </Container>
</BaseLayout>
