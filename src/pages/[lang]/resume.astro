---
import type { GetStaticPaths } from 'astro'

import { getEntry, render } from 'astro:content'

import { getLocale, supportedLocales, t } from '@/app/i18n'
import BaseLayout from '@/app/layouts/base-layout.astro'
import { Header } from '@/components/header'
import { ResumeDownloadButton, ResumeHeader, ResumePositions } from '@/components/resume'
import Container from '@/shared/ui/container.astro'
import TypographyH2 from '@/shared/ui/typography/typography-h2.astro'

export const getStaticPaths = (async () =>
  supportedLocales.map(lang => ({ params: { lang } }))) satisfies GetStaticPaths

const locale = getLocale(Astro.currentLocale)

const summaryEntry = await getEntry('general', `${locale}/summary`)
const Summary = summaryEntry ? (await render(summaryEntry)).Content : null
const skillsEntry = await getEntry('general', `${locale}/skills`)
const SkillsAndLanguagesContent = skillsEntry ? (await render(skillsEntry)).Content : null
const educationEntry = await getEntry('general', `${locale}/education`)
const EducationContent = educationEntry ? (await render(educationEntry)).Content : null
---

<BaseLayout title=`${t(Astro.currentLocale, 'resume')} – ${t(Astro.currentLocale, 'fullName')}`>
  <Header slot="header" />

  <Container content>
    <article
      class="markdown text-fg py-12 [--resume-gap:1.5rem] print:py-0 print:[--resume-gap:0.25rem] print:[&_:is(p,li)]:p-0 print:[&_:is(p,li)]:text-sm print:[&_:is(p,li)]:leading-normal print:[&_a]:no-underline [&_p]:mt-0"
    >
      <ResumeHeader />

      <TypographyH2 class="mt-1 mb-2 text-2xl">
        {t(Astro.currentLocale, 'summary')}
      </TypographyH2>
      {Summary && <Summary />}

      <TypographyH2 class="mt-8 mb-2 text-2xl">
        {t(Astro.currentLocale, 'workingExperience')}
      </TypographyH2>
      <ResumePositions />

      <TypographyH2 class="mt-8 mb-2 text-2xl">
        {t(Astro.currentLocale, 'education')}
      </TypographyH2>
      {EducationContent && <EducationContent />}

      <TypographyH2 class="mt-8 mb-2 text-2xl">
        {t(Astro.currentLocale, 'skillsAndLanguages')}
      </TypographyH2>
      {SkillsAndLanguagesContent && <SkillsAndLanguagesContent />}

      <ResumeDownloadButton />
    </article>
  </Container>
</BaseLayout>
