---
import type { HTMLAttributes } from 'astro/types'

interface Props extends HTMLAttributes<'a'> {}

const { class: className, ...props } = Astro.props
---

<a
  class:list={[
    'bg-btn text-btn-fg focus-ring hoverable:bg-btn-hover active:bg-btn-active block max-w-[350px] cursor-pointer rounded border-none px-12 py-2 text-center no-underline',
    className
  ]}
  {...props}><slot /></a
>
