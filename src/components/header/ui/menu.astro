---
import type { HTMLAttributes } from 'astro/types'

import { getRelativeLocaleUrl } from 'astro:i18n'

import { getLocale, t } from '@/app/i18n'
import { getTestId } from '@/shared/functions/getTestId'
import { siteInfo } from '@/shared/site-info'
import TypographySpan from '@/shared/ui/typography/typography-span.astro'

import LangSwitchLink from './lang-switch-link.astro'
import ThemeSegmentedControl from './theme-segmented-control.astro'

interface Props extends HTMLAttributes<'nav'> {}

const { class: className, ...props } = Astro.props

const pathname = new URL(Astro.request.url).pathname
const locale = getLocale(Astro.currentLocale)
const currentRoute = pathname.slice(1).replace(`${locale}`, '').slice(0, -1) || '/'
---

<nav
  data-testid={getTestId('menu')}
  class:list={[
    'bg-menu menu--closed fixed inset-y-[var(--header-height)_0] left-0 w-full grid-rows-[auto_repeat(2,min-content)] justify-items-center gap-4 overflow-y-auto p-4 px-[var(--page-padding-x)] sm:static sm:grid sm:grid-cols-[auto_repeat(2,min-content)] sm:grid-rows-[unset] sm:items-center sm:bg-transparent sm:p-0',
    className
  ]}
  {...props}
>
  <ul class="m-0 flex list-none flex-col items-center justify-center gap-2 p-0 sm:flex-row sm:justify-self-start">
    {
      siteInfo.navigation.map(({ id, route }) => (
        <li class="p-1">
          <a
            data-testid={getTestId(`open-${id}-link`)}
            class={`text-fg focus-ring hoverable:bg-menu-hover hoverable:text-menu-hover-fg inline-flex rounded-md bg-transparent p-2 no-underline transition-colors duration-[var(--link-hover-duration)] ${currentRoute === route ? 'opacity-70' : ''}`}
            href={getRelativeLocaleUrl(locale, route)}
            data-prefetch
          >
            <TypographySpan>{t(Astro.currentLocale, id)}</TypographySpan>
          </a>
        </li>
      ))
    }
  </ul>

  <LangSwitchLink />
  <ThemeSegmentedControl />
</nav>
