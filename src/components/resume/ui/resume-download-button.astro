---
import { getLocale, t } from '@/app/i18n'
import ButtonLink from '@/shared/ui/button-link.astro'

import { RESUME_FILENAMES_BY_LOCALE } from '../constants'

const locale = getLocale(Astro.currentLocale)
---

<ButtonLink
  class="mx-auto mt-8 print:hidden"
  download=`${RESUME_FILENAMES_BY_LOCALE[locale]}.pdf`
  href=`/files/${RESUME_FILENAMES_BY_LOCALE[locale]}.pdf`
>
  {t(Astro.currentLocale, 'download')}
</ButtonLink>
