---
interface Props {
  rating: number | null
  class?: string
}

const { class: className, rating } = Astro.props

const stars = rating
  ? Array.from({ length: 5 }, (_, i) => {
      const diff = rating - i
      if (diff >= 1) return 'full'
      if (diff >= 0.5) return 'half'
      return 'empty'
    })
  : []
---

{
  rating !== null && rating > 0 && (
    <div class:list={['flex gap-0.5', className]} aria-label={`${rating} out of 5`}>
      {stars.map(type => (
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="text-fg-subtle"
          aria-hidden="true"
        >
          {type === 'full' && (
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
              fill="currentColor"
            />
          )}
          {type === 'half' && (
            <>
              <path
                d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                fill="currentColor"
                opacity="0.25"
              />
              <path d="M12 2v15.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="currentColor" />
            </>
          )}
          {type === 'empty' && (
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
              fill="currentColor"
              opacity="0.25"
            />
          )}
        </svg>
      ))}
    </div>
  )
}
