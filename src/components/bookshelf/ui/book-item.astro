---
import type { ImageMetadata } from 'astro'

import { Picture } from 'astro:assets'

import type { Locale } from '@/app/i18n'

import { t } from '@/app/i18n'

import StarRating from './star-rating.astro'

interface Props {
  author: { en: string; ru: string }
  cover: ImageMetadata
  descriptionHtml?: string
  language: Locale
  locale: Locale
  rating: number | null
  skipped?: boolean
  title: { en: string; ru: string }
  type: 'fiction' | 'non-fiction'
}

const { author, cover, descriptionHtml, language, locale, rating, skipped, title, type } = Astro.props

const displayTitle = title[locale] || title.en || title.ru
const displayAuthor = author[locale] || author.en || author.ru
const langLabels = { en: 'langEn', ru: 'langRu' } as const
---

<li class="flex items-start gap-4 py-3" data-type={type}>
  <Picture
    src={cover}
    formats={['avif', 'webp']}
    alt={displayTitle}
    class="border-border h-auto w-16 shrink-0 rounded-sm border object-cover"
    width={64}
    densities={[1.5, 2]}
    loading="lazy"
    quality={80}
  />

  <div class="flex min-w-0 flex-1 flex-col gap-0.5">
    <span class="text-fg font-sans text-base leading-snug font-medium">
      {displayTitle}
    </span>
    <span class="text-fg-subtle text-sm">
      {displayAuthor}
    </span>
    <div class="mt-0.5 flex items-center gap-2">
      {!skipped && <StarRating rating={rating} />}
      <span class="text-fg-subtle bg-surface border-border rounded border px-1.5 py-0 text-xs leading-relaxed">
        {t(locale, langLabels[language])}
      </span>
      {
        skipped && (
          <span class="text-fg-subtle bg-surface border-border rounded border px-1.5 py-0 text-xs leading-relaxed">
            {t(locale, 'skipped')}
          </span>
        )
      }
    </div>
    {
      descriptionHtml && (
        <div
          class="text-fg-muted mt-2 max-w-prose text-sm leading-relaxed [&_a]:underline [&_ol]:list-decimal [&_ol]:pl-5 [&_p]:mt-2 [&_ul]:list-disc [&_ul]:pl-5 [&>*:first-child]:mt-0"
          set:html={descriptionHtml}
        />
      )
    }
  </div>
</li>
