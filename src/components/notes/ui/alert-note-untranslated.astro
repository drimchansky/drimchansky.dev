---
import type { HTMLAttributes } from 'astro/types'

import { Icon } from 'astro-icon/components'

import { t } from '@/app/i18n'
import Alert from '@/shared/ui/alert.astro'
import TypographySpan from '@/shared/ui/typography/typography-span.astro'

interface Props extends HTMLAttributes<'div'> {}

const { class: className, ...props } = Astro.props
---

<Alert class:list={[className]} {...props}>
  <TypographySpan class="text-sm">
    <Icon name="languages" class="inline min-h-4 min-w-4 align-text-top" aria-hidden />
    {t(Astro.currentLocale, 'untranslated')}
  </TypographySpan>
</Alert>
